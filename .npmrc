# pnpm settings — project-scoped
# Copy package files instead of hard-linking. Hard-linking is faster but
# can silently half-succeed on Windows when another process (running
# Electron, Windows Search, antivirus) touches the file mid-link, leaving
# empty directories behind. Copy is slower but reliable.
package-import-method=copy

# Before running any package script, verify node_modules matches the
# lockfile and auto-install what's missing. Catches the "empty extracted
# package" class of problem before it manifests as a runtime error.
verify-deps-before-run=install
